{
  "name": "sigscan-ts",
  "version": "1.1.0",
  "type": "module",
  "description": "Ultra-fast, zero-dependency binary signature scanner for Node.js and Bun",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "sigscan-ts": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "dev": "tsup --watch",
    "clean": "bun -e \"import{rmSync}from'fs';try{rmSync('dist',{recursive:true,force:true})}catch{}\"",
    "bench": "bun run examples/bench/bench.ts",
    "prepublishOnly": "bun run clean && bun run type-check && bun run build"
  },
  "keywords": [
    "sigscan",
    "signature",
    "pattern-scanner",
    "binary-scanner",
    "reverse-engineering",
    "gamedata",
    "ida-pattern",
    "cheat-engine",
    "x64dbg",
    "byte-pattern",
    "cs2",
    "sourcemod"
  ],
  "author": "Kőrösfalvi \"K4ryuu\" Martin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/K4ryuu/sigscan-ts.git"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "mitata": "^1.0.34",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "sideEffects": false
}